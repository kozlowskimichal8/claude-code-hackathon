<?xml version="1.0" encoding="utf-8"?>
<!--
  NOTE: Do not change the connection string without updating it
  in THREE places: this file, Admin/EndOfDay.aspx.cs (separate conn string!),
  and the App_Code/DBHelper.cs which has a fallback hardcoded string.

  K.Patel 2014: "TODO: move this to environment variable"
  (still a TODO in 2024)
-->
<configuration>

  <connectionStrings>
    <!-- Primary database. Prod server: NWLSQL01. Dev: DEVDB01 -->
    <add name="NorthwindLogistics"
         connectionString="Data Source=NWLSQL01;Initial Catalog=NorthwindLogistics;User ID=nwl_app;Password=P@ssw0rd2009!;Connect Timeout=30;Application Name=NWLWebApp"
         providerName="System.Data.SqlClient" />
    <!-- Reporting connection (read-only user, slightly higher timeout) -->
    <add name="NorthwindLogisticsReporting"
         connectionString="Data Source=NWLSQL01;Initial Catalog=NorthwindLogistics;User ID=nwl_report;Password=r3port2011!;Connect Timeout=120;Application Name=NWLReports"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="AppVersion"       value="4.7.1" />
    <add key="AppEnvironment"   value="Production" />   <!-- remember to change on dev deploy (someone always forgets) -->
    <add key="SessionTimeout"   value="30" />
    <add key="MaxUploadSizeMB"  value="10" />
    <add key="EnableDebugInfo"  value="false" />        <!-- set true on dev, never on prod (set true twice in 2019) -->
    <add key="DefaultPageSize"  value="50" />
    <add key="FileServerPath"   value="\\fileserver01\pod\" />
    <add key="SmtpServer"       value="mail.northwindlogistics.com" />
    <add key="AdminEmail"       value="admin@northwindlogistics.com" />
    <!-- Legacy key from v2, still read by some old code, DO NOT REMOVE -->
    <add key="ConnectionString" value="Data Source=NWLSQL01;Initial Catalog=NorthwindLogistics;User ID=nwl_app;Password=P@ssw0rd2009!" />
  </appSettings>

  <system.web>
    <compilation debug="false" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" maxRequestLength="10240" executionTimeout="300" />

    <!-- Forms auth. Login page hasn't been updated since 2010. -->
    <authentication mode="Forms">
      <forms loginUrl="~/Login.aspx" timeout="30" />
    </authentication>

    <!-- Everyone has access by default, authorization done in code-behind -->
    <authorization>
      <allow users="*" />
    </authorization>

    <!-- Turned off after the 2017 YSOD leak. Custom error page is just a blank page. -->
    <customErrors mode="RemoteOnly" defaultRedirect="~/Error.aspx" />

    <!-- ViewState not encrypted. "Internal app, not needed." -->
    <pages viewStateEncryptionMode="Never">
      <namespaces>
        <add namespace="System.Web.UI.WebControls" />
      </namespaces>
    </pages>

    <!-- Session stored in-proc. Doesn't work on web farm (we have two servers now) -->
    <sessionState mode="InProc" timeout="30" />

    <httpHandlers />
    <httpModules />
  </system.web>

  <system.webServer>
    <defaultDocument>
      <files>
        <add value="Default.aspx" />
      </files>
    </defaultDocument>
    <staticContent>
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
    </staticContent>
    <!-- Needed for large POD uploads -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>

</configuration>
